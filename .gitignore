# Python
__pycache__/
*.py[cod]
*.egg-info/

# Virtual environments
.venv/
venv/

# Tooling caches
.pytest_cache/
.ruff_cache/

# Editor / OS
.DS_Store
Thumbs.db

# Data (raw script / generated pipeline output)
data/raw/**/*.dec
data/raw/**/*.txt
data/normalized/**/*.json
data/extracted/**/*.json
data/reports/**/*.json
data/reports/**/*.md
!data/**/.gitkeep

# Real full-text game scripts must never live in tests/fixtures/ —
# only small handcrafted samples belong there.
tests/fixtures/parser/CAB-csl_script_*.dec

# Real data dry-run output (docs/runbooks/Real_Data_Dry_Run.md).
# workspace/experiments, workspace/notebooks, workspace/reviews,
# workspace/tmp keep their existing tracked (.gitkeep + curated docs)
# behavior; only the dry-run scratch output area is ignored here.
workspace/dry_runs/

# Real data Wiki render dry-run output (docs/runbooks/Real_Data_Wiki_Render_Dry_Run.md).
workspace/wiki_preview/
workspace/wiki_render/
site_src/
docs/wiki_generated/
generated/wiki/

# Character dictionary review packet / confirmed-batch local input
# (docs/runbooks/Character_Dictionary_Review.md). これらは人間確認済み
# mapping・実データ由来displayName等を含みうるローカル専用ファイルであり、
# docs/templates/配下の合成テンプレートとは別物としてignoreする。
workspace/review_packets/
workspace/local_inputs/
character_confirmed_batch_*.yaml
character_dictionary_review_batch_*.yaml
character_dictionary_review_batch_*.csv

# Character profile Wiki import candidates
# (docs/runbooks/Character_Profile_Wiki_Import.md)。実Wiki由来のraw HTML・
# プロフィール候補は人間確認前のローカル専用データであり、
# tests/fixtures/配下の合成HTMLとは別物としてignoreする。
workspace/profile_import/
character_profile_candidates_batch_*.yaml
character_profile_candidates_batch_*.csv
wiki_member_profiles_batch_*.yaml
wiki_member_profiles_batch_*.csv
*.wiki.html

# MkDocs build output (docs/runbooks/MkDocs_Local_Preview.md)
site/

# Story manifest candidates
# (docs/architecture/05_Parser/Story_Manifest_Design.md、
# scripts/build_story_manifest_candidates.py)。実raw DEC配置から機械的に
# 生成した候補は人間確認前のローカル専用データであり、
# docs/templates/story_manifest_template.yaml (合成データ) とは別物として
# ignoreする。実.decファイル自体も、data/raw/以外の場所へローカルに
# 展開される可能性があるため、念のため全体をignoreする。
workspace/story_manifest/
story_manifest_candidates_*.yaml
story_manifest_candidates_*.json
*.dec

# Story title/subtitle import candidates
# (docs/runbooks/Story_Title_Subtitle_Import.md、
# scripts/build_story_title_subtitle_candidates.py)。実Wiki一覧・実CSV由来の
# title/subtitle候補は人間確認前のローカル専用データであり、
# docs/templates/story_title_subtitle_candidates_template.yaml (合成データ)
# とは別物としてignoreする。以前character_confirmed_batch_*.yamlパターンで
# テンプレート自身が誤って一致した不具合と同種のため、明示的にnegationで
# 除外する。
story_title_subtitle_candidates_*.yaml
story_title_subtitle_candidates_*.csv
!docs/templates/story_title_subtitle_candidates_template.yaml
title_subtitle_rows*.csv

# Story/Episode summary drafts
# (docs/architecture/06_AI/Story_Summary_Design.md、
# feature/story-summary-schema-implementation)。review.statusがreviewed/
# approvedになるまでのAI生成・下書きsummaryはローカル専用データであり、
# knowledge/summaries/stories/ (review済みのみcommit) とは別物として
# ignoreする。
workspace/summary_drafts/

# Evidence Index generation dry-run output
# (docs/architecture/06_AI/Evidence_Index_Design.md、
# scripts/build_evidence_index_candidates.py、
# feature/evidence-index-generation-dry-run)。Normalized Story JSON/
# Extraction Resultから機械生成したEvidence Index候補・reportは
# 人間レビュー前のローカル専用データであり、knowledge/evidence/stories/
# (review済みのみcommit) とは別物としてignoreする。
workspace/evidence_index_dry_runs/

# Secrets / logs
.env
.env.*
!.env.example
*.log
