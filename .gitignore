# Python
__pycache__/
*.py[cod]
*.egg-info/

# Virtual environments
.venv/
venv/

# Tooling caches
.pytest_cache/
.ruff_cache/

# Editor / OS
.DS_Store
Thumbs.db

# Data (raw script / generated pipeline output)
data/raw/**/*.dec
data/raw/**/*.txt
data/normalized/**/*.json
data/extracted/**/*.json
data/reports/**/*.json
data/reports/**/*.md
!data/**/.gitkeep

# Real full-text game scripts must never live in tests/fixtures/ —
# only small handcrafted samples belong there.
tests/fixtures/parser/CAB-csl_script_*.dec

# Real data dry-run output (docs/runbooks/Real_Data_Dry_Run.md).
# workspace/experiments, workspace/notebooks, workspace/reviews,
# workspace/tmp keep their existing tracked (.gitkeep + curated docs)
# behavior; only the dry-run scratch output area is ignored here.
workspace/dry_runs/

# Real data Wiki render dry-run output (docs/runbooks/Real_Data_Wiki_Render_Dry_Run.md).
workspace/wiki_preview/
workspace/wiki_render/
site_src/
docs/wiki_generated/
generated/wiki/

# Character dictionary review packet / confirmed-batch local input
# (docs/runbooks/Character_Dictionary_Review.md). これらは人間確認済み
# mapping・実データ由来displayName等を含みうるローカル専用ファイルであり、
# docs/templates/配下の合成テンプレートとは別物としてignoreする。
workspace/review_packets/
workspace/local_inputs/
character_confirmed_batch_*.yaml
character_dictionary_review_batch_*.yaml
character_dictionary_review_batch_*.csv

# Character profile Wiki import candidates
# (docs/runbooks/Character_Profile_Wiki_Import.md)。実Wiki由来のraw HTML・
# プロフィール候補は人間確認前のローカル専用データであり、
# tests/fixtures/配下の合成HTMLとは別物としてignoreする。
workspace/profile_import/
character_profile_candidates_batch_*.yaml
character_profile_candidates_batch_*.csv
wiki_member_profiles_batch_*.yaml
wiki_member_profiles_batch_*.csv
*.wiki.html

# Secrets / logs
.env
.env.*
!.env.example
*.log
