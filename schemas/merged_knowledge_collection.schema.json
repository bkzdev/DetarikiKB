{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://detariki-kb/schemas/merged_knowledge_collection.schema.json",
  "title": "Merged Knowledge Collection (Stage B merge engine preview)",
  "description": "Stage B merge engine (agents/merger/) が返すcollection wrapperのスキーマ。schemas/merged_knowledge.schema.json (単一のmerged entity) とは別物で、複数episode_extractionの検証結果とentities/reportをまとめたpreview形式。docs/architecture/06_AI/Merged_Knowledge_Design.md 準拠。現時点ではentities配下は常に空配列 (本格的なcandidate mergeは未実装)。",

  "type": "object",
  "required": [
    "schemaVersion",
    "documentType",
    "generatedAt",
    "sourceDocuments",
    "entities",
    "report"
  ],
  "additionalProperties": false,

  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "collection wrapperのスキーマバージョン (agents/merger/models.py COLLECTION_SCHEMA_VERSION)"
    },
    "documentType": {
      "type": "string",
      "description": "固定値 merged_knowledge_collection",
      "const": "merged_knowledge_collection"
    },
    "generatedAt": {
      "type": "string",
      "description": "生成日時 (ISO 8601)"
    },
    "sourceDocuments": {
      "type": "array",
      "description": "merge対象となったvalid inputのepisode_extractionドキュメント一覧",
      "items": { "$ref": "#/definitions/SourceDocument" }
    },
    "entities": {
      "$ref": "#/definitions/EntitiesContainer"
    },
    "report": {
      "$ref": "#/definitions/MergeReport"
    }
  },

  "definitions": {

    "CandidateCounts": {
      "type": "object",
      "description": "Stage A episode_extractionのcandidate配列8種の件数 (agents/merger/models.py CANDIDATE_ARRAY_KEYS)。report全体・sourceDocuments個別のどちらでも同じ形を使う共通定義",
      "required": [
        "characters",
        "locations",
        "organizations",
        "items",
        "lore",
        "events",
        "relationships",
        "timelineCandidates"
      ],
      "additionalProperties": false,
      "properties": {
        "characters": { "type": "integer", "minimum": 0 },
        "locations": { "type": "integer", "minimum": 0 },
        "organizations": { "type": "integer", "minimum": 0 },
        "items": { "type": "integer", "minimum": 0 },
        "lore": { "type": "integer", "minimum": 0 },
        "events": { "type": "integer", "minimum": 0 },
        "relationships": { "type": "integer", "minimum": 0 },
        "timelineCandidates": { "type": "integer", "minimum": 0 }
      }
    },

    "MergedEntityCounts": {
      "type": "object",
      "description": "merged entity 8種の件数 (agents/merger/models.py MERGED_ENTITY_KEYS)。CandidateCountsとはtimelineCandidates/timelineのキー名が異なる点に注意 (Merged_Knowledge_Design.md §7)",
      "required": [
        "characters",
        "locations",
        "organizations",
        "items",
        "lore",
        "events",
        "relationships",
        "timeline"
      ],
      "additionalProperties": false,
      "properties": {
        "characters": { "type": "integer", "minimum": 0 },
        "locations": { "type": "integer", "minimum": 0 },
        "organizations": { "type": "integer", "minimum": 0 },
        "items": { "type": "integer", "minimum": 0 },
        "lore": { "type": "integer", "minimum": 0 },
        "events": { "type": "integer", "minimum": 0 },
        "relationships": { "type": "integer", "minimum": 0 },
        "timeline": { "type": "integer", "minimum": 0 }
      }
    },

    "SourceDocument": {
      "type": "object",
      "description": "merge対象となった1つのepisode_extraction入力を表す (PR #17 sourceDocuments拡張形式)",
      "required": ["path", "documentId", "extractionVersion", "candidateCounts"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "入力ファイルパス"
        },
        "documentId": {
          "type": ["string", "null"],
          "description": "ドキュメント識別子 (現状episodeIdをそのまま使う)"
        },
        "storyId": {
          "type": ["string", "null"],
          "description": "Story ID (任意)"
        },
        "episodeId": {
          "type": ["string", "null"],
          "description": "Episode ID (任意)"
        },
        "storyCategory": {
          "type": ["string", "null"],
          "description": "ストーリー種別 (任意)"
        },
        "extractionVersion": {
          "type": ["string", "null"],
          "description": "extractionRun.extractionVersion (Stage A実行バージョン)"
        },
        "extractionRunId": {
          "type": ["string", "null"],
          "description": "extractionRunの参照ID (将来拡張用、現状の実装では未使用)"
        },
        "candidateCounts": {
          "$ref": "#/definitions/CandidateCounts",
          "description": "このドキュメント単体のcandidate件数内訳"
        }
      }
    },

    "InputResultStatus": {
      "type": "string",
      "description": "1入力の処理結果。valid=検証通過 / invalid=読み込めたが検証失敗 / skipped=1件も解決できなかった",
      "enum": ["valid", "invalid", "skipped"]
    },

    "InputResult": {
      "type": "object",
      "description": "merge report内のinputResultsの1エントリ (agents/merger/models.py InputResult)",
      "required": ["path", "status", "errors", "warnings"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "解決できた場合はファイルパス、解決できなかった場合は元のraw --input引数"
        },
        "status": { "$ref": "#/definitions/InputResultStatus" },
        "errors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "MergeReport": {
      "type": "object",
      "description": "merge report骨格 (Merged_Knowledge_Design.md §11.2, agents/merger/models.py MergeReport)",
      "required": [
        "inputFiles",
        "resolvedInputFiles",
        "validInputs",
        "invalidInputs",
        "skippedInputs",
        "candidateCounts",
        "mergedEntityCounts",
        "conflictsCount",
        "unresolvedCount",
        "unresolvedEntityCounts",
        "conflictCounts",
        "warningCounts",
        "entityTypeSummaries",
        "inputSummaries",
        "inputResults",
        "warnings",
        "errors"
      ],
      "additionalProperties": false,
      "properties": {
        "inputFiles": {
          "type": "integer",
          "description": "raw --input引数の件数 (ディレクトリ/glob展開前)",
          "minimum": 0
        },
        "resolvedInputFiles": {
          "type": "integer",
          "description": "展開・重複排除後に実際に見つかったファイル件数",
          "minimum": 0
        },
        "validInputs": {
          "type": "integer",
          "minimum": 0
        },
        "invalidInputs": {
          "type": "integer",
          "minimum": 0
        },
        "skippedInputs": {
          "type": "array",
          "description": "1件もファイルへ解決できなかったraw引数の一覧",
          "items": { "type": "string" }
        },
        "candidateCounts": {
          "$ref": "#/definitions/CandidateCounts",
          "description": "全valid input合算のcandidate件数"
        },
        "mergedEntityCounts": {
          "$ref": "#/definitions/MergedEntityCounts",
          "description": "entities配下に実際に生成されたmerged entityの件数 (Character/Location/Organization最小merge導入により追加)"
        },
        "conflictsCount": {
          "type": "integer",
          "description": "全merged entityのconflicts配列の合計件数",
          "minimum": 0
        },
        "unresolvedCount": {
          "type": "integer",
          "description": "status: unresolvedのmerged entity件数",
          "minimum": 0
        },
        "unresolvedEntityCounts": {
          "$ref": "#/definitions/MergedEntityCounts",
          "description": "status: unresolvedのmerged entity件数のtype別内訳 (unresolvedCountの内訳。形はMergedEntityCountsと同一のため定義を再利用する)"
        },
        "conflictCounts": {
          "$ref": "#/definitions/ConflictCounts",
          "description": "全merged entityのconflicts集計 (conflictsCountの内訳。severity別/conflictType別/entity type別)"
        },
        "warningCounts": {
          "$ref": "#/definitions/WarningCounts",
          "description": "report.warningsの概要集計"
        },
        "entityTypeSummaries": {
          "$ref": "#/definitions/EntityTypeSummaries",
          "description": "entity type別の簡易サマリー (candidate件数/merged件数/unresolved件数/conflict件数)"
        },
        "inputSummaries": {
          "type": "array",
          "description": "入力ファイル別のサマリー (inputResultsにdocumentId/episodeId/candidateCountsを付与したもの)",
          "items": { "$ref": "#/definitions/InputSummary" }
        },
        "inputResults": {
          "type": "array",
          "items": { "$ref": "#/definitions/InputResult" }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "errors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "manualOverrides": {
          "$ref": "#/definitions/ManualOverridesReport",
          "description": "manual override適用結果 (agents/merger/overrides.py)。--overrides未指定時は本フィールド自体が存在しない (任意プロパティ、既存挙動を壊さないため)"
        }
      }
    },

    "ManualOverrideResult": {
      "type": "object",
      "description": "1件のmanual override適用結果 (agents/merger/overrides.py OverrideResult)",
      "required": ["overrideId", "targetId", "status", "reason", "fieldsChanged"],
      "additionalProperties": false,
      "properties": {
        "overrideId": { "type": "string" },
        "targetId": { "type": ["string", "null"] },
        "status": {
          "type": "string",
          "enum": ["applied", "skipped", "error"]
        },
        "reason": { "type": "string" },
        "fieldsChanged": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "ManualOverridesReport": {
      "type": "object",
      "description": "manual override適用の集計 (Merged_Knowledge_Design.md §8)",
      "required": [
        "enabled",
        "overrideFiles",
        "appliedCount",
        "skippedCount",
        "errorCount",
        "results"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "--overridesが指定されたかどうか"
        },
        "overrideFiles": {
          "type": "array",
          "description": "適用したoverrideファイルパスの一覧",
          "items": { "type": "string" }
        },
        "appliedCount": { "type": "integer", "minimum": 0 },
        "skippedCount": { "type": "integer", "minimum": 0 },
        "errorCount": { "type": "integer", "minimum": 0 },
        "results": {
          "type": "array",
          "items": { "$ref": "#/definitions/ManualOverrideResult" }
        }
      }
    },

    "ConflictCounts": {
      "type": "object",
      "description": "全merged entityのconflicts集計 (report.conflictsCountの内訳)。byType/byEntityTypeのキー集合は固定しない (conflictTypeは自由文字列、entity typeは実際にconflictを持つtypeのみ)",
      "required": ["total", "bySeverity", "byType", "byEntityType"],
      "additionalProperties": false,
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "bySeverity": {
          "type": "object",
          "description": "severity (info/warning/error) 別の件数",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "byType": {
          "type": "object",
          "description": "conflictType (field_value_conflict/relationship_conflict/timeline_conflict等) 別の件数",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "byEntityType": {
          "type": "object",
          "description": "entity type (characters/locations/.../timeline) 別の件数",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },

    "WarningCounts": {
      "type": "object",
      "description": "report.warningsの概要集計",
      "required": ["total", "unresolvedRelationships", "skippedOverrides", "other"],
      "additionalProperties": false,
      "properties": {
        "total": {
          "type": "integer",
          "description": "report.warningsの総件数",
          "minimum": 0
        },
        "unresolvedRelationships": {
          "type": "integer",
          "description": "source/targetを解決できずrelationship mergeをskipした件数",
          "minimum": 0
        },
        "skippedOverrides": {
          "type": "integer",
          "description": "--overrides適用時のmanualOverrides.skippedCountをそのまま反映する (未指定時は0)",
          "minimum": 0
        },
        "other": {
          "type": "integer",
          "description": "上記いずれにも分類されなかったwarnings件数",
          "minimum": 0
        }
      }
    },

    "EntityTypeSummary": {
      "type": "object",
      "description": "1つのentity typeについてのcandidate/merged/unresolved/conflict件数サマリー",
      "required": ["candidateCount", "mergedCount", "unresolvedCount", "conflictCount"],
      "additionalProperties": false,
      "properties": {
        "candidateCount": { "type": "integer", "minimum": 0 },
        "mergedCount": { "type": "integer", "minimum": 0 },
        "unresolvedCount": { "type": "integer", "minimum": 0 },
        "conflictCount": { "type": "integer", "minimum": 0 }
      }
    },

    "EntityTypeSummaries": {
      "type": "object",
      "description": "entity type別の簡易サマリー (MergedEntityCountsと同じ8キー)",
      "required": [
        "characters",
        "locations",
        "organizations",
        "items",
        "lore",
        "events",
        "relationships",
        "timeline"
      ],
      "additionalProperties": false,
      "properties": {
        "characters": { "$ref": "#/definitions/EntityTypeSummary" },
        "locations": { "$ref": "#/definitions/EntityTypeSummary" },
        "organizations": { "$ref": "#/definitions/EntityTypeSummary" },
        "items": { "$ref": "#/definitions/EntityTypeSummary" },
        "lore": { "$ref": "#/definitions/EntityTypeSummary" },
        "events": { "$ref": "#/definitions/EntityTypeSummary" },
        "relationships": { "$ref": "#/definitions/EntityTypeSummary" },
        "timeline": { "$ref": "#/definitions/EntityTypeSummary" }
      }
    },

    "InputSummary": {
      "type": "object",
      "description": "入力ファイル1件分のサマリー (inputResultsにdocumentId/episodeId/candidateCountsを付与したもの)。invalid/skippedな入力はdocumentId/episodeId/candidateCountsがnullになる。mergedEntityCountsは常にnull (merged entityは複数episodeをまたいで統合されうるため、1入力への排他的な帰属を今回は計算しない。方針はTASKS.md参照)",
      "required": [
        "path",
        "status",
        "documentId",
        "episodeId",
        "candidateCounts",
        "mergedEntityCounts"
      ],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "status": { "$ref": "#/definitions/InputResultStatus" },
        "documentId": { "type": ["string", "null"] },
        "episodeId": { "type": ["string", "null"] },
        "candidateCounts": {
          "anyOf": [
            { "$ref": "#/definitions/CandidateCounts" },
            { "type": "null" }
          ]
        },
        "mergedEntityCounts": {
          "anyOf": [
            { "$ref": "#/definitions/MergedEntityCounts" },
            { "type": "null" }
          ]
        }
      }
    },

    "MergedEntityArray": {
      "type": "array",
      "description": "TODO: 本格的なcandidate mergeを実装した際は、items を schemas/merged_knowledge.schema.json への $ref に差し替える。JSON Schema間のクロスファイル参照 (RefResolver設定) が必要になるため、現時点ではentitiesが常に空配列であることに合わせ、objectの配列として緩く許容するに留める (TASKS.md参照)。",
      "items": { "type": "object" }
    },

    "EntitiesContainer": {
      "type": "object",
      "description": "merged entityの8配列 (Merged_Knowledge_Design.md §7: timelineCandidates候補はtimelineへ集約されるため、report.candidateCountsとキー名が異なる点に注意)",
      "required": [
        "characters",
        "locations",
        "organizations",
        "items",
        "lore",
        "events",
        "relationships",
        "timeline"
      ],
      "additionalProperties": false,
      "properties": {
        "characters": { "$ref": "#/definitions/MergedEntityArray" },
        "locations": { "$ref": "#/definitions/MergedEntityArray" },
        "organizations": { "$ref": "#/definitions/MergedEntityArray" },
        "items": { "$ref": "#/definitions/MergedEntityArray" },
        "lore": { "$ref": "#/definitions/MergedEntityArray" },
        "events": { "$ref": "#/definitions/MergedEntityArray" },
        "relationships": { "$ref": "#/definitions/MergedEntityArray" },
        "timeline": { "$ref": "#/definitions/MergedEntityArray" }
      }
    }
  }
}
