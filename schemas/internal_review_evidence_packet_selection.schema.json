{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://detariki-kb/schemas/internal_review_evidence_packet_selection.schema.json",
  "title": "Internal Review Evidence Packet Selection",
  "description": "ローカル限定の明示selection file。内部evidence IDのみを保持し、raw・title・pathは保持しない。",
  "type": "object",
  "required": ["selectionVersion", "evidenceIds"],
  "additionalProperties": false,
  "properties": {
    "selectionVersion": { "type": "integer", "const": 1 },
    "evidenceIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "maxLength": 256, "pattern": "^[A-Z][A-Z0-9_]*$" }
    }
  }
}
